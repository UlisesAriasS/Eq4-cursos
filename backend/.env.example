# ─────────────────────────────────────────────
#  Variables de entorno — Backend Eq4-Cursos
# ─────────────────────────────────────────────
# Copia este archivo a .env y ajusta los valores

# Conexión MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=eq4user
DB_PASSWORD=eq4password
DB_NAME=eq4cursos

# URL completa (se construye automáticamente si no se sobreescribe)
# DATABASE_URL=mysql+pymysql://eq4user:eq4password@localhost:3306/eq4cursos

# API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS — orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
